{
    "prefix": "clean",
    "dataset": "cifar224",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "model_name": "clip_fc",
    "backbone_type": "clip",
    "device": ["0"],
    "seed": [1993],
    "total_class_num": 100,
    "use_dol": true,
    "train_epoch": 10,
    "init_lr": 0.01,
    "weight_decay": 0.0005,
    "dol_epoch": 10,
    "dol_lr": 0.001,
    "dol_alpha": 1.0,
    "dol_lambda_sep": 1.0,
    "dol_eps": 1e-8
}
